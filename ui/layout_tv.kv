MDScreen:
    md_bg_color: 0.82, 0.90, 1, 1

    MDNavigationLayout:

        MDScreenManager:
            id: screen_manager

            MDScreen:
                name: "main"

                MDBoxLayout:
                    orientation: "vertical"

                    MDTopAppBar:
                        title: "PyServe"
                        anchor_title: "left"
                        elevation: 0
                        md_bg_color: app.custom_blue

                    MDBoxLayout:
                        orientation: "vertical"
                        padding: "10dp"
                        spacing: "10dp"

                        # =========================
                        # ADDRESS BAR
                        # =========================
                        MDCard:
                            size_hint_y: None
                            height: dp(70)
                            radius: [12]
                            elevation: 2
                            md_bg_color: 0.98, 0.98, 0.98, 1

                            MDBoxLayout:
                                orientation: "horizontal"
                                padding: [dp(25), 0, dp(10), 0]
                                spacing: dp(10)

                                MDLabel:
                                    text: app.url_display if app.url_display else "http://localhost:9666"
                                    halign: "left"
                                    valign: "middle"
                                    theme_text_color: "Custom"
                                    text_color: app.custom_blue
                                    font_style: "H6"
                                    bold: True
                                    size_hint_x: 1
                                    shorten: False
                                    text_size: self.size

                                MDRelativeLayout:
                                    size_hint_x: None
                                    width: dp(70)

                                    Image:
                                        source: "assets/web_green.png" if app.running else "assets/web_red.png"
                                        size_hint: None, None
                                        size: dp(42), dp(42)
                                        pos_hint: {"center_x": 0.5, "center_y": 0.5}

                        # LOG
                        MDCard:
                            size_hint: 1, 1
                            elevation: 2
                            radius: [12]
                            padding: "10dp"

                            ScrollView:
                                MDLabel:
                                    id: log_label
                                    text: ""
                                    halign: "left"
                                    valign: "top"
                                    size_hint_y: None
                                    height: self.texture_size[1]
                                    text_size: self.width, None

                        # BUTTON
                        MDBoxLayout:
                            size_hint_y: None
                            height: dp(80)
                            padding: [0, 5, 0, 5]

                            Widget:

                            MDRaisedButton:
                                id: start_button
                                text: app.button_text
                                font_style: "H6"
                                size_hint: 0.7, 1
                                md_bg_color: app.custom_blue
                                on_release: app.toggle_server()

                            Widget: